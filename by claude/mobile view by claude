import 'package:flutter/material.dart';
import 'pagination_manager.dart';
import '/logic/editor_bloc/rich_text_model.dart';
import '/logic/editor_bloc/rich_text_controller.dart';

class MobileView extends StatefulWidget {
  final PaginationManager paginationManager;
  final List<RichSpan> spans;
  final bool isBold;
  final bool isItalic;
  final bool isUnderline;
  final TextAlign alignment;
  final double fontSize;
  final String fontFamily;
  final UndoHistoryController? undoController;
  final ValueNotifier<TextSelection>? selectionNotifier;
  final ValueChanged<List<RichSpan>>? onSpansChanged;

  const MobileView({
    super.key,
    required this.paginationManager,
    required this.spans,
    required this.isBold,
    required this.isItalic,
    required this.isUnderline,
    required this.alignment,
    required this.fontSize,
    required this.fontFamily,
    this.undoController,
    this.selectionNotifier,
    this.onSpansChanged,
  });

  @override
  State<MobileView> createState() => _MobileViewState();
}

class _MobileViewState extends State<MobileView> {
  late RichTextController _controller;
  late FocusNode _focusNode;


  @override
  void initState() {
    super.initState();

    // Use RichTextController with spans
    _controller = RichTextController(
      spans: widget.spans,
      defaultFontSize: widget.fontSize,
      defaultFontFamily: widget.fontFamily,
    );

    _focusNode = FocusNode();

    _controller.addListener(_onSelectionChanged);

    WidgetsBinding.instance
        .addPostFrameCallback((_) => _restoreCursor());

    widget.paginationManager.addListener(_syncFromManager);
  }

  @override
  void didUpdateWidget(MobileView oldWidget) {
    super.didUpdateWidget(oldWidget);
    // Sync spans from bloc when they change externally
    // (e.g. after ApplyFormatToSelection)
    
    final newText =
        RichSpan.spansToPlainText(widget.spans);
    if (_controller.text != newText) {
      final sel = _controller.selection;
      _controller.updateSpans(
        widget.spans,
        selection: sel.isValid ? sel : null,
      );
    }
  }

  void _syncFromManager() {
    final managerText =
        widget.paginationManager.fullText;
    if (_controller.text != managerText) {
      final previous =
          widget.paginationManager.globalCursorPosition;
      // Don't replace spans — just fix cursor position
      _controller.selection = TextSelection.collapsed(
          offset: previous.clamp(
              0, _controller.text.length));
    }
  }

  void _onSelectionChanged() {
    widget.selectionNotifier?.value =
        _controller.selection;
  }

  void _restoreCursor() {
    final pos =
        widget.paginationManager.globalCursorPosition;
    _focusNode.requestFocus();
    _controller.selection = TextSelection.collapsed(
        offset: pos.clamp(0, _controller.text.length));
  }

  @override
  void dispose() {
    _controller.removeListener(_onSelectionChanged);
    widget.paginationManager
        .removeListener(_syncFromManager);
    _controller.dispose();
    _focusNode.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Container(
      color: Colors.white,
      child: TextField(
        controller: _controller,
        focusNode: _focusNode,
        undoController: widget.undoController,
        maxLines: null,
        expands: true,
        onChanged: (value) {
          widget.paginationManager.updateContent(value);
          widget.paginationManager
              .setGlobalCursorPosition(
                  _controller.selection.baseOffset);
          // Notify bloc of span changes
          widget.onSpansChanged?.call(_controller.spans);
        },
        // Style is now handled per-span inside
        // RichTextController.buildTextSpan —
        // this base style is just a fallback
        style: TextStyle(
          fontSize: widget.fontSize,
          fontFamily: widget.fontFamily,
          height: 1.5,
          color: Colors.black,
        ),
        textAlign: widget.alignment,
        decoration: const InputDecoration(
          border: InputBorder.none,
          contentPadding:
              EdgeInsets.fromLTRB(20, 20, 20, 40),
        ),
      ),
    );
  }
}